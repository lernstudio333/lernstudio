{
  "compilerOptions": {
    "target": "ES2019",
    "lib": ["ES2019"],
    "module": "None",               /* GAS requires no module system — all globals */
    "moduleResolution": "node",
    "rootDir": "tmp",
    "outDir": "build",
    "types": [
      "google-apps-script"
    ],
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": false,       /* Files share global scope */
    "declaration": false
  },
  "include": [
    "tmp/**/*.ts"
  ]
}
